[Unit]
Description=OneDrive Sync Client Daemon
After=network-online.target graphical-session.target
Wants=network-online.target graphical-session.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
ExecStart=/usr/bin/python3 -m odsc.daemon
Restart=on-failure
RestartSec=5
# Cap graceful-shutdown wait so a stuck stop can't block restarts for the
# 90s systemd default before SIGKILL.
TimeoutStopSec=20

[Install]
WantedBy=graphical-session.target
